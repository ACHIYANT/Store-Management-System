PORT=3000
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=STORE_MANAGEMENT_DB_DEV
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql
SYNC_DB=false
TRUST_PROXY=false
ENABLE_MIGRATION=true
ENABLE_STATIC_UPLOADS=false

AUTH_BASE_URL=http://localhost:3001/api/v1
AUTH_REQUEST_TIMEOUT_MS=5000
AUTH_INTERNAL_SERVICE_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
AUTH_INTERNAL_SERVICE_NAME=StoreManagementService

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_DEV_ALLOW_ANY=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,x-access-token,x-csrf-token,X-Requested-With
CORS_MAX_AGE_SECONDS=86400

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=500

UPLOAD_MAX_FILE_BYTES=20971520
MIGRATION_MAX_FILE_BYTES=31457280
FILE_ENCRYPTION_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

AUTH_COOKIE_NAME=token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token
CSRF_PROTECTION_ENABLED=true

ENABLE_HSTS=false

FORENSIC_AUDIT_ENABLED=true
FORENSIC_AUDIT_HOT_DAYS=90
FORENSIC_AUDIT_COLD_DAYS=365
FORENSIC_AUDIT_SEARCH_DEFAULT_DAYS=30
FORENSIC_AUDIT_SEARCH_MAX_LIMIT=500
FORENSIC_AUDIT_ARCHIVE_DIR=src/audit-archive
FORENSIC_AUDIT_ARCHIVE_INTERVAL_MS=21600000
FORENSIC_AUDIT_ARCHIVE_BATCH_SIZE=2000
FORENSIC_AUDIT_ARCHIVE_MAX_BATCHES_PER_RUN=5
FORENSIC_AUDIT_SKIP_PATHS=
